{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  "effortLevel": "low",
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": false
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/usagizmo/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "language": "Japanese",
  "model": "claude-fable-5[1m]",
  "permissions": {
    "allow": [
      "Bash",
      "Bash(gh pr merge:*)",
      "Edit",
      "Glob",
      "Read",
      "WebFetch",
      "WebSearch",
      "Skill(tidy:*)",
      "Skill(docs:*)",
      "Skill(commit:*)"
    ],
    "defaultMode": "auto"
  },
  "skillOverrides": {
    "find-skills": "off",
    "sentry-cli": "off",
    "supabase-postgres-best-practices": "off",
    "vercel-cli": "off"
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "~/.claude/statusline.py",
    "type": "command"
  },
  "verbose": true
}