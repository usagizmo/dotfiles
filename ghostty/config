# 背景色（暗め）
background = #1a1b1b

# フォントを読みやすくする
font-thicken

# フォントの指定
font-family = Moralerspace Neon
font-size = 11

# cmd+w を Ghostty の close_surface から解放し、herdr の close_pane に流す
keybind = super+w=unbind

# option を Alt として送る（alt+g 等の herdr keybind が © などの記号入力にならないように）
macos-option-as-alt = true

# 以下、herdr を優先してコメントアウト

